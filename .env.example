# Modèle de configuration. Copiez ce fichier en ".env" et adaptez les valeurs.
# Le vrai fichier ".env" ne doit JAMAIS être versionné (voir .gitignore).

# --- Django ---
DJANGO_SECRET_KEY=remplacez-moi-par-une-cle-secrete-aleatoire
DJANGO_DEBUG=True
# Pour l'intégration USSD via un tunnel (ngrok), ajoutez ses domaines :
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.ngrok-free.app,.ngrok-free.dev,.ngrok.io

# --- PostgreSQL ---
POSTGRES_DB=ussd_shop
POSTGRES_USER=ussd
POSTGRES_PASSWORD=ussd_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
